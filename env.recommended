# Recommended local med-agent-hub settings.
# The hub is the client-facing endpoint; this URL is its model-serving backend.
LLM_BASE_URL=http://localhost:8077
LLM_API_KEY=

# Optional OpenMRS patient-record source. Inline chart requests work without it.
QUERYSTORE_BASE_URL=
QUERYSTORE_USERNAME=
QUERYSTORE_PASSWORD=

# Optional deterministic drug-safety data. Defaults use the bundled curated datasets.
DRUG_SAFETY_SOURCE_FORMAT=json
# DRUG_SAFETY_DATASET_PATH=/absolute/path/to/drug-reference.json
# DRUG_SAFETY_CROSS_REACTIVITY_PATH=/absolute/path/to/cross-reactivity-groups.json
DRUG_SAFETY_WEIGHT_CONCEPT_UUID=5089AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
DRUG_SAFETY_WEIGHT_MAX_AGE_DAYS=90
